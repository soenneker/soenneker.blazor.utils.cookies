@page "/"
@using Microsoft.Extensions.Logging
@inject ICookiesUtil Cookies
@inject ILogger<Index> Logger

<Div Space="Space.Y.Is6">
    <DemoPanel Title="Get / set" Description="Store and read a cookie by name.">
        <Field>
            <FieldLabel For="c-name">Name</FieldLabel>
            <FieldBody>
                <Input Id="c-name" @bind-Value="_cookieName" />
            </FieldBody>
        </Field>
        <Field>
            <FieldLabel For="c-val">Value</FieldLabel>
            <FieldBody>
                <Input Id="c-val" @bind-Value="_cookieValue" />
            </FieldBody>
        </Field>
        <DemoButtonRow>
            <Button OnClick="SetCookie">Set</Button>
            <Button OnClick="GetCookie" Variant="ButtonVariant.Secondary">Get</Button>
        </DemoButtonRow>
        @if (_getResult != null)
        {
            <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm">Value: <Strong>@_getResult</Strong></Paragraph>
        }
    </DemoPanel>

    <DemoPanel Title="Remove" Description="Delete a cookie by name.">
        <Field>
            <FieldLabel For="c-remove">Name</FieldLabel>
            <FieldBody>
                <Input Id="c-remove" @bind-Value="_removeName" />
            </FieldBody>
        </Field>
        <DemoButtonRow>
            <Button OnClick="RemoveCookie" Variant="ButtonVariant.Destructive">Remove</Button>
        </DemoButtonRow>
    </DemoPanel>

    <DemoPanel Title="All cookies" Description="Enumerate every cookie visible to this page.">
        <DemoButtonRow>
            <Button OnClick="LoadAllCookies" Variant="ButtonVariant.Outline">Refresh list</Button>
        </DemoButtonRow>
        @if (_allCookies != null)
        {
            @if (_allCookies.Count == 0)
            {
                <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">No cookies.</Paragraph>
            }
            else
            {
                <Div Space="Space.Y.Is2">
                    @foreach (var kv in _allCookies)
                    {
                        <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm"><Code>@kv.Key</Code> = @kv.Value</Paragraph>
                    }
                </Div>
            }
        }
    </DemoPanel>
</Div>

@code {
    private string _cookieName = "demo";
    private string _cookieValue = "hello";
    private string? _getResult;
    private string _removeName = "demo";
    private IReadOnlyDictionary<string, string>? _allCookies;

    private async Task SetCookie()
    {
        try
        {
            await Cookies.Set(_cookieName, _cookieValue);
            Logger.LogInformation("Set cookie {Name}", _cookieName);
            _getResult = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Set failed");
        }
    }

    private async Task GetCookie()
    {
        try
        {
            _getResult = await Cookies.Get(_cookieName);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Get failed");
        }
    }

    private async Task RemoveCookie()
    {
        try
        {
            await Cookies.Remove(_removeName);
            Logger.LogInformation("Removed cookie {Name}", _removeName);
            _getResult = null;
            _allCookies = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Remove failed");
        }
    }

    private async Task LoadAllCookies()
    {
        try
        {
            _allCookies = await Cookies.GetAll();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "GetAll failed");
        }
    }
}
